# wp-claude-template cheatsheet — environment template
# Copy this to .env and fill in your real values.
# .env is gitignored so your secrets stay out of git.

# Gemini API key — used by /api/polish.php to refine your prompts.
# Get a free key at: https://aistudio.google.com/app/apikey
# Leave blank to disable the "Polish with AI" button (the prompt wizard still works).
GEMINI_API_KEY=

# Which Gemini model to use. Defaults to gemini-2.5-flash (fast, free tier).
# Other options: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.5-flash
